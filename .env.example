# Bazzite AI Notebooks - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Model Storage
# =============================================================================
# Directory for saving/caching models (default: /workspace/models)
# This path persists across container restarts when using /workspace
MODELS_DIR=/workspace/models

# =============================================================================
# HuggingFace
# =============================================================================
# Required for downloading gated models (e.g., Mistral, Llama)
# Get your token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# =============================================================================
# Cloudflare R2 (Optional - for model/data storage)
# =============================================================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_URL=

# =============================================================================
# API Keys (Optional)
# =============================================================================
# Voyage AI - for embeddings
VOYAGE_API_KEY=

# GitHub - for MCP server integration
GITHUB_PERSONAL_ACCESS_TOKEN=
